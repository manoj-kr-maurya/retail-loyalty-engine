generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Shop {
  id          String   @id @map("_id") @default(auto()) @db.ObjectId
  phoneNumber String
  name        String
  address     String?
  createdAt   DateTime @default(now())
}

model Customer {
  id          String   @id @map("_id") @default(auto()) @db.ObjectId
  phoneNumber String   @unique
  name        String?
  points      Int      @default(0)
  shopId      String?  @db.ObjectId
  createdAt   DateTime @default(now())
}

model Transaction {
  id            String   @id @map("_id") @default(auto()) @db.ObjectId
  shopId        String   @db.ObjectId
  customerPhone String
  amount        Float
  points        Int
  createdAt     DateTime @default(now())
}

model LoyaltyRule {
  id             String   @id @map("_id") @default(auto()) @db.ObjectId
  shopId         String   @db.ObjectId
  pointsPerValue Int
  valuePerPoint  Float
  createdAt      DateTime @default(now())
}

model Reward {
  id            String   @id @map("_id") @default(auto()) @db.ObjectId
  shopId        String   @db.ObjectId
  title         String
  pointsNeeded  Int
  createdAt     DateTime @default(now())
}
