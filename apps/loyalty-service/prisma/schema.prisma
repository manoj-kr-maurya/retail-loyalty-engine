generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Transaction {
  id            String   @id @map("_id") @default(auto()) @db.ObjectId
  shopId        String   @db.ObjectId
  customerPhone String
  amount        Float
  points        Int
  createdAt     DateTime @default(now())
}
